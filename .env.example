# App metadata
APP_NAME=Air Quality Web GIS
APP_VERSION=2.1.0

# Security
SECRET_KEY=replace-with-strong-random-secret

# CORS
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=false
DATA_TIMEOUT_SECONDS=8

# Data source
# auto: try WAQI then fallback synthetic
# waqi: WAQI only (will fail if token unavailable)
# synthetic: local generator only
DATA_SOURCE=synthetic
WAQI_TOKEN=replace-with-waqi-token
WAQI_CITIES=jakarta,bandung,surabaya,mataram

# Governance & operational controls
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
DATA_STALE_MINUTES=30
ADMIN_API_KEY=replace-with-admin-key-for-audit-endpoint
MIN_ACCEPTABLE_VALID_RATE_PCT=85

# Auth & RBAC (optional)
AUTH_ENABLED=false
JWT_SECRET=replace-with-jwt-secret
JWT_SECRETS=primary:replace-with-jwt-secret,previous:replace-with-old-jwt-secret
JWT_ACTIVE_KID=primary
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_ISSUER=airq-webgis
JWT_AUDIENCE=airq-api
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin-change-me
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=viewer-change-me

# Retention and backups
RETENTION_DAYS=30

# Alert channels: comma-separated values from [slack,telegram,email]
ALERT_CHANNELS=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
ALERT_DISPATCH_KEY=

# Grafana local admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin-change-me

# Database
# Default local demo uses SQLite.
# For Docker/Postgres stack, replace with:
# DATABASE_URL=postgresql+psycopg2://airqadmin:replace-with-strong-db-password@db:5432/airqgis
POSTGRES_USER=airqadmin
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=airqgis
DATABASE_URL=sqlite:///./airqgis.db

# Async workers
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
